# ─────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────

# MongoDB Atlas connection string
# 1. Go to https://cloud.mongodb.com
# 2. Create a free cluster → Connect → Drivers → copy the URI
# 3. Replace <username>, <password>, and <dbname> below
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/loop?retryWrites=true&w=majority

# Port – Render sets this automatically, leave as 3001 for local dev
PORT=3001

# Your Netlify frontend URL (used for CORS)
# Leave * during development; set exact URL in production
FRONTEND_URL=*
